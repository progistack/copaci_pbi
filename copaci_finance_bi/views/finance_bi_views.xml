<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action client qui charge le composant OWL -->
    <record id="action_finance_bi_dashboard" model="ir.actions.client">
        <field name="name">BI Finance</field>
        <field name="tag">copaci_finance_bi.dashboard</field>
        <field name="target">main</field>
    </record>

    <!-- Menu principal — visible uniquement pour les utilisateurs
         ayant au moins le droit "Lecture seule" en comptabilité.
         Ce groupe est géré depuis : Configuration → Utilisateurs → Droits d'accès → Comptabilité.
         Le module ne crée aucun groupe propre : il s'appuie sur les groupes natifs Odoo. -->
    <menuitem
        id="menu_finance_bi_root"
        name="BI Finance"
        action="action_finance_bi_dashboard"
        sequence="6"
        web_icon="copaci_finance_bi,static/description/icon.png"
        groups="account.group_account_readonly"
    />
</odoo>
