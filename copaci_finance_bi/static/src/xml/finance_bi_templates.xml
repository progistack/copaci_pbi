<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="copaci_finance_bi.Dashboard">
        <div class="o_finance_bi_container" style="width:100%;height:100%;position:relative;">
            <!-- Loading indicator -->
            <div t-if="state.loading"
                 style="position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;background:#f0f4f8;z-index:10;">
                <div style="text-align:center;">
                    <div style="width:40px;height:40px;border:3px solid #e2e8f0;border-top:3px solid #0f766e;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 16px;"></div>
                    <p style="color:#475569;font-size:14px;font-weight:500;">Chargement du dashboard Finance...</p>
                </div>
            </div>
            <!-- Dashboard iframe -->
            <iframe t-att-src="state.iframeSrc"
                    class="o_finance_bi_iframe"
                    t-on-load="onIframeLoad"
                    style="width:100%;height:100%;border:none;display:block;position:absolute;top:0;left:0;"
                    allowfullscreen="true" />
        </div>
    </t>

</templates>
